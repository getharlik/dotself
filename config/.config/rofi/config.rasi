configuration {
    modi:                        "drun,run,filebrowser,window";
    show-icons:                  true;
    display-drun:                " ";
    display-run:                 " ";
    display-filebrowser:         " ";
    display-window:              " ";
    drun-display-format:         "{name}";
    window-format:               "{w}{t}";
    icon-theme:                  "Papirus-Dark";
    font:                        "JetBrainsMono Nerd Font 10";
}

@theme "styles/style-1"