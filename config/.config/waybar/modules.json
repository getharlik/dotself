{

    "custom/separator": {
        "format": " |"
    },


    "clock": {
        "format": "пАЧ  {:%I:%M %p}",
        "tooltip": true,
        "tooltip-format": "{:%a, %D}",
        "on-click": "hyprctl dispatch exec '[float; size 500 280] kitty -e tty-clock -c'"
    },
    "backlight": {
        "scroll-step" : 1,
        "format": "{icon} {percent}%",
        "tooltip": false,
        "format-icons": ["оПХ","оПЦ","оПЧ","оПШ","оПЩ","оПЪ","оПЫ","оПЬ","оПЭ","оПЮ","оПЯ","оП†","оП°","оПҐ","оП£"]
    },
    "pulseaudio": {
        "scroll-step": 1,
        "format": "{icon}  {volume}%",
        "format-icons": ["пА¶", "пАІ", "пА®"],
        "tooltip-format": "{desc}",
        "on-click": "pavucontrol"
    },



    "hyprland/workspaces": {
      "on-click": "activate",
      "format": "{name}",
      "sort-by-number": true,
      "persistent-only": true,
      "persistent-workspaces": {
        "DP-2": [1,2,3,4,5],
        "HDMI-A-1": [6,7,8]
      }
    },
  


    "custom/exit": {
        "format": "пАС",
        "tooltip-format": "Power menu",
        "on-click": "~/.config/waybar/scripts/power.sh"
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% у∞ВД",
        "format-icons": ["у∞БЇ", "у∞Бї", "у∞БЉ", "у∞Бљ", "у∞БЊ", "у∞Бњ", "у∞ВА", "у∞ВБ", "у∞ВВ", "у∞Бє"],
        "states": {
            "warning": 30,
            "critical": 15
        },
        "tooltip-format-charging": "Health: {health}\n{timeTo}",
        "tooltip=format": "Health: {health}"
    },
    "network": {
        "format-wifi": "{essid} пЗЂ ",
        "format-ethernet": "у∞ИА ",
        "format-disconnected": " вЪ† ",
        "tooltip-format": "{frequency} GHz | {signalStrength}% Strength\n{ifname} via {gwaddr}",
        "tooltip-format-ethernet": "{ifname} via {gwaddr}\n{cidr} IP(V4)",
        "tooltip-format-disconnected": "Disconnected"
    },
    "bluetooth": {
        "format-on": "у∞В∞",
        "format-off": "у∞В≤",
        "format-disabled": "у∞В≤",
        "format-connected": "у∞В∞",
        "tooltip": true,
        "tooltip-format-on": "Active",
        "tooltip-format-off": "Disabled",
        "tooltip-format-connected": "{device_alias}  пЙА  {device_battery_percentage}%",
        "interval": 30,
        "on-click": "blueman-manager"
    },
    "hyprland/language": {
        "format": "пЖЂ  {short}"
    },
    "temperature": {
        "interval": 30,
        "format": "{temperatureC}¬∞ {icon}",
        "tooltip": false,
        "critical-threshold": 90,
        "format-icons": ["пЛЛ","пЛК","пЛЙ","пЛИ","пЛЗ"]
    },
    "memory": {
        "interval": 30,
        "format": "{percentage}% оњЕ",
        "tooltip-format": "{used:0.1f}G/{total:0.1f}G",
        "states": {
            "warning": 80,
            "critical": 90
        }
    },
    "cpu": {
        "interval": 30,
        "format":"{usage}% пЛЫ",
        "states": {
            "warning": 80,
            "critical": 90
        }
    }
}